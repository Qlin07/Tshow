<Window x:Class="Tshow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tshow - 软件使用时长监测"
        Height="640" Width="900"
        MinHeight="480" MinWidth="720"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="12"
            Background="{StaticResource BackgroundBrush}"
            BorderBrush="#3A3A3A"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Tshow"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,4,0">
                        <Button Content="—"
                                FontSize="12"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="MinimizeButton_Click" />
                        <Button Content="✕"
                                FontSize="12"
                                Width="32" Height="32"
                                Background="Transparent"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                        <Button x:Name="TimelineTab"
                                Content="时间线"
                                Cursor="Hand"
                                FontSize="13"
                                Background="Transparent"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="0"
                                Padding="16,6"
                                Click="TimelineTab_Click" />
                        <Button x:Name="MonitorTab"
                                Content="进程监测"
                                Cursor="Hand"
                                FontSize="13"
                                Background="Transparent"
                                Foreground="{StaticResource AccentLightBrush}"
                                BorderThickness="0"
                                Padding="16,6"
                                Click="MonitorTab_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,12,0">
                        <Button Content="开机自启"
                                Style="{StaticResource SecondaryButton}"
                                FontSize="11"
                                Padding="8,4"
                                Command="{Binding ToggleStartupCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid x:Name="MonitorPage" Visibility="Visible">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="300" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="16,12,8,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="8"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="已追踪进程"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Margin="0,0,0,8" />

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding TrackedProcesses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource SurfaceLightBrush}"
                                                            CornerRadius="6"
                                                            Padding="10,8"
                                                            Margin="0,0,0,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ProcessName}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="14" FontWeight="SemiBold" />
                                                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                                    <Run Text="今日: " /><Run Text="{Binding TodayUsage}" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Content="&#xE74D;"
                                                                    FontFamily="Segoe MDL2 Assets"
                                                                    FontSize="14"
                                                                    Width="28" Height="28"
                                                                    Background="Transparent"
                                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                                    BorderThickness="0"
                                                                    Cursor="Hand"
                                                                    VerticalAlignment="Center"
                                                                    Command="{Binding DataContext.RemoveProcessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding ProcessName}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <GridSplitter Grid.Column="1"
                                      Width="3"
                                      Background="Transparent"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch" />

                        <Grid Grid.Column="2" Margin="8,12,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="当前任务栏进程"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="刷新"
                                                Style="{StaticResource SecondaryButton}"
                                                FontSize="11" Padding="8,4"
                                                Command="{Binding RefreshCurrentProcessesCommand}" />
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Run Text="共 " /><Run Text="{Binding CurrentProcesses.Count, Mode=OneWay}" /><Run Text=" 个" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CurrentProcesses}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceBrush}"
                                                    CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding ProcessName}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="12" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding WindowTitle}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="10"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="180" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Content="添加追踪"
                                                            FontSize="10" Padding="8,3"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Command="{Binding DataContext.AddProcessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding ProcessName}"
                                                            Visibility="{Binding AddVisibility}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="已追踪"
                                                               Foreground="{StaticResource SuccessBrush}"
                                                               FontSize="10" VerticalAlignment="Center"
                                                               Visibility="{Binding TrackedVisibility}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>

                <ScrollViewer x:Name="TimelinePage" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource SurfaceBrush}"
                                Padding="12,8"
                                Margin="12,12,12,0"
                                CornerRadius="8,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="查看日期"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <ComboBox ItemsSource="{Binding TimelineDates}"
                                          SelectedItem="{Binding SelectedTimelineDate}"
                                          Width="140"
                                          Height="26"
                                          FontSize="12"
                                          Background="{StaticResource SurfaceLightBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="#4A4A4A"
                                          BorderThickness="1">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat={}{0:yyyy-MM-dd}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Canvas Grid.Row="1" x:Name="TimelineCanvas"
                                MinHeight="200"
                                Background="{StaticResource SurfaceBrush}"
                                Margin="12,0,12,12" />
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="3"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{StaticResource SuccessBrush}"
                             Margin="0,0,6,0" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
